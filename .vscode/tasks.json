{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Current C File",
      "type": "shell",
      "command": "C:\\msys64\\mingw64\\bin\\gcc.exe",
      "args": [
        "${file}",
        "-g",
        "-O0",
        "-std=c11",
        "-Wall",
        "-Wextra",
        "-o",
        "${fileBasenameNoExtension}.exe"
      ],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
