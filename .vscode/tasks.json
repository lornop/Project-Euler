{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Current C File",
      "type": "shell",
      "command": "gcc",
      "args": [
        "${file}",
        "-g",
        "-O0",
        "-std=c11",
        "-Wall",
        "-Wextra",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
